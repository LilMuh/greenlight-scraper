# 复制成 .env 再填。.env 已被 gitignore。
PORT=8090

# 写库用的 Postgres（schema 由 greenlight-database 的 Liquibase 拥有）
DATABASE_URL=postgres://greenlight:greenlight@localhost:5432/greenlight

# 指纹浏览器服务（用来绕过 Cloudflare + reCAPTCHA 抓 CPS 这类站点）。
# 对接开源 Open-Anti-Browser 的 Open-API：https://github.com/Wtcity22/Open-Anti-Browser
#   BROWSER_SERVICE_URL  服务地址，留空默认 http://127.0.0.1:8000
#   BROWSER_PROFILE_ID   要启动的浏览器 profile id（必填，本地的、不进仓库）
#   BROWSER_API_KEY      Open-API key，留空则自动从服务的 info 接口获取
BROWSER_SERVICE_URL=
BROWSER_PROFILE_ID=
BROWSER_API_KEY=
